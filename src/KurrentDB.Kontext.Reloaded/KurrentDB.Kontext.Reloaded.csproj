<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\KurrentDB.Kontext.Contracts\KurrentDB.Kontext.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Core.Api" />
    <!-- Match the version Kontext.Contracts was generated against (3.32.1 via CPM); Google.Api.CommonProtos
         otherwise drags in a lower 3.31.1 transitively, tripping CS1705 against the contract assembly. -->
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Google.Api.CommonProtos" />
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Edges\Mcp\" />
    <Folder Include="Infrastructure\FluentValidation\" />
    <Folder Include="Memory\" />
    <Folder Include="Retrieval\" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="KurrentDB.Kontext.Reloaded.csproj.DotSettings" />
  </ItemGroup>

</Project>
