<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Assembly stays KurrentDB.Kontext.Embeddings; namespace is Kurrent.Kontext.* per repo convention. -->
    <RootNamespace>Kurrent.Kontext.Embeddings</RootNamespace>
    <Description>Kontext embeddings SDK — local ONNX text embedding generators behind Microsoft.Extensions.AI.</Description>
    <!-- AOT-safe (reflection-free) config binding for OnnxModelManifest via the source generator. -->
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>
  </PropertyGroup>

  <ItemGroup>
    <!-- Prototype's EmbeddingService.GetEmbedding is internal and exercised by the Kontext test suite. -->
    <InternalsVisibleTo Include="KurrentDB.Kontext.Tests" />
    <InternalsVisibleTo Include="KurrentDB.Plugins.Kontext.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AWSSDK.Extensions.Bedrock.MEAI" />
    <PackageReference Include="Google.Cloud.VertexAI.Extensions" />
    <PackageReference Include="OllamaSharp" />
    <PackageReference Include="OpenAI" />
    <PackageReference Include="Microsoft.ML.Tokenizers" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" />
    <PackageReference Include="Microsoft.Extensions.AI" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="DotNext.Threading" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\KurrentDB.Kontext.Models\KurrentDB.Kontext.Models.csproj" />
  </ItemGroup>

</Project>
