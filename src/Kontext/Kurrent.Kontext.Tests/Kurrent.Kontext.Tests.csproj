<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
		<EnablePreviewFeatures>true</EnablePreviewFeatures>
		<TreatWarningsAsErrors>false</TreatWarningsAsErrors>
		<!-- SKEXP0001/SKEXP0070: the SK ONNX Bert embedding generator used by the KontextStore tests is
		     experimental; TreatWarningsAsErrors is forced on by src/Directory.Build.targets. -->
		<NoWarn>$(NoWarn);NU1904;SKEXP0001;SKEXP0070</NoWarn>
	</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
    <!-- Real ONNX Bert embedding generator for the KontextStore tests (no fakes). -->
    <PackageReference Include="Microsoft.SemanticKernel.Connectors.Onnx" />
  </ItemGroup>
  
	<ItemGroup>
		<Using Include="TUnit" />
		<Using Include="TUnit.Core" />
		<Using Include="KurrentDB.Testing" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Kurrent.Kontext\Kurrent.Kontext.csproj" />
		<ProjectReference Include="..\..\KurrentDB.Testing\KurrentDB.Testing.csproj" />
	</ItemGroup>
  
</Project>
