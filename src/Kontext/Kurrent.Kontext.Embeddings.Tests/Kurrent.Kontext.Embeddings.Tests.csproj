<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
		<EnablePreviewFeatures>true</EnablePreviewFeatures>
		<TreatWarningsAsErrors>false</TreatWarningsAsErrors>
		<NoWarn>$(NoWarn);NU1904</NoWarn>
	</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
  </ItemGroup>
  
	<ItemGroup>
		<Using Include="TUnit" />
		<Using Include="TUnit.Core" />
		<Using Include="KurrentDB.Testing" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Kurrent.Kontext.Embeddings\Kurrent.Kontext.Embeddings.csproj" />
		<ProjectReference Include="..\..\KurrentDB.Testing\KurrentDB.Testing.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Configuration" />
	</ItemGroup>

</Project>
