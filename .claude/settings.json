{
  "permissions": {
    "deny": [
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.cer)",
      "Read(./**/*.crt)",
      "Read(./**/*.der)",
      "Read(./**/*.jks)",
      "Read(./**/*.keystore)",
      "Read(./**/*.ppk)",
      "Read(./**/*.ovpn)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./**/id_ecdsa*)",
      "Read(./**/*credential*)",
      "Read(./**/*password*)",
      "Read(./**/*secret*)",
      "Read(./**/*token*.json)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.env)",
      "Read(./**/.npmrc)",
      "Read(./**/.pypirc)",
      "Read(./**/.netrc)",
      "Read(./**/.pgpass)",
      "Read(./**/.htpasswd)",
      "Read(./**/.git-credentials)",
      "Read(./**/kubeconfig)",
      "Read(./**/*.kubeconfig)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfstate.*)",
      "Read(./**/launchSettings.json)",
      "Read(./**/secrets.json)",
      "Read(./**/secrets/**)",
      "Read(./**/appsettings.*.Local.json)",
      "Read(./**/appsettings.Development.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)",
      "Read(~/.pgpass)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude.json)",
      "Read(~/**/*.key)",
      "Read(~/**/*.pem)",
      "Read(~/**/*.p12)",
      "Read(~/**/*.pfx)",
      "Read(~/**/id_rsa*)",
      "Read(~/**/id_ed25519*)",
      "Read(~/**/id_ecdsa*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-sensitive-reads.py\""
          }
        ]
      }
    ]
  }
}
